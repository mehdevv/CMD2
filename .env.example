# ====================================================================
# Scale software — environment variables
# Copy this file to `.env` (or `.env.local`) and fill the values.
# Never commit the real `.env` — it is already git-ignored.
# ====================================================================

# -- Supabase --------------------------------------------------------
# From Supabase dashboard → Settings → API.
# `VITE_` prefix = exposed to the browser (safe for publishable/anon).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# New-style key format. Either name works — pick ONE.
# If your Supabase project shows "Publishable key", use the sb_publishable_... value.
# If it shows "anon public", use that JWT.
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key

# -- Server / Edge Function only (NEVER expose to the browser) -------
# Used by server-side scripts, Supabase Edge Functions, and migrations.
SUPABASE_SECRET_KEY=your_secret_or_service_role_key
SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# -- App --------------------------------------------------------------
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=Scale

# -- Optional: LLM provider for the 4 automation agents --------------
# You can store these per-org in the DB instead, via the agent config pages.
# These are only a fallback for local development.
# VITE_OPENAI_API_KEY=
# VITE_ANTHROPIC_API_KEY=
# VITE_GOOGLE_API_KEY=
